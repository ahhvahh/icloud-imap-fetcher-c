# Example variables for Codex environment
# Adjust values in the Codex environment configuration screen.

export PROJECT_ROOT="/workspace/icloud-imap-fetcher-c"
export IMAP_USERNAME="your-email@icloud.com"
export IMAP_APP_PASSWORD="CHANGE_ME"
export IMAP_URL="imaps://imap.mail.me.com"
export IMAP_MAILBOX="INBOX/Processar"
export IMAP_SEARCH_FILTER="UNSEEN"
export IMAP_MARK_AS_READ="false"
export MAIL_FROM_CONTAINS=""
export MAIL_SUBJECT_CONTAINS=""
export ATTACHMENT_NAME_PREFIX="mail_"
export MAX_MESSAGES_PER_RUN="5"
export DRY_RUN="false"
export MAIL_DEST_DIR="$PROJECT_ROOT/.runtime/messages"
export ATTACHMENT_DEST_DIR="$PROJECT_ROOT/.runtime/attachments"
export LOG_DIR="$PROJECT_ROOT/.runtime/logs"
export LOG_RETENTION_DAYS="7"
export LOG_LEVEL="info"
export INTERVAL_SECONDS="300"
